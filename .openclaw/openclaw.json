{
  "agents": {
    "defaults": {
      "model": {
        "primary": "deepseek/deepseek-v4-flash",
        "fallbacks": ["deepseek/deepseek-v4-pro"]
      },
      "models": {
        "deepseek/deepseek-v4-pro": { "alias": "pro" },
        "deepseek/deepseek-v4-flash": { "alias": "flash" }
      }
    },
    "list": [{ "id": "main", "identity": { "name": "Trợ lý", "emoji": "✨" } }]
  },
  "gateway": { "mode": "local" },
  "channels": {
    "telegram": {
      "enabled": true,
      "reactionLevel": "minimal",
      "dmPolicy": "allowlist",
      "allowFrom": ["DAN_TELEGRAM_ID_CUA_BAN_VAO_DAY"]
    }
  },
  "commands": { "ownerAllowFrom": ["telegram:DAN_TELEGRAM_ID_CUA_BAN_VAO_DAY"] },
  "models": {
    "providers": {
      "deepseek": {
        "baseUrl": "https://api.deepseek.com",
        "api": "openai-completions",
        "models": [
          { "id": "deepseek-v4-flash", "name": "DeepSeek V4 Flash", "reasoning": true, "contextWindow": 131072, "maxTokens": 8192, "compat": { "thinkingFormat": "deepseek" } },
          { "id": "deepseek-v4-pro", "name": "DeepSeek V4 Pro", "reasoning": true, "contextWindow": 131072, "maxTokens": 8192, "compat": { "thinkingFormat": "deepseek" } }
        ]
      }
    }
  },
  "plugins": {
    "entries": {
      "deepseek": { "enabled": true },
      "browser": { "enabled": false },
      "canvas": { "enabled": false },
      "device-pair": { "enabled": false },
      "phone-control": { "enabled": false },
      "talk-voice": { "enabled": false }
    }
  }
}
