# ============================================================
#  KEY CỦA MÂY — copy file này thành ".env" rồi điền giá trị thật
#    cp .env.example .env
#  ⚠️ KHÔNG commit file .env lên GitHub (đã được .gitignore chặn sẵn).
# ============================================================

# --- BẮT BUỘC ---
DEEPSEEK_API_KEY=          # key DeepSeek (platform.deepseek.com → API Keys)
TELEGRAM_BOT_TOKEN=        # token bot Telegram (chat @BotFather → /newbot)
# (ID Telegram của bạn KHÔNG ở đây — sửa trong openclaw.json: commands.ownerAllowFrom)

# --- TUỲ CHỌN (để trống nếu chưa dùng skill tương ứng) ---
JINA_API_KEY=             # skill jina: đọc web/social + research (jina.ai)
APIFY_TOKEN=              # skill social-extract: đọc bài FB/IG/TikTok/X (apify.com)
COACHIO_API_KEY=          # skill coachio-image: tạo ảnh
